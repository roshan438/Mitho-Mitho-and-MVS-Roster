rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userRef(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function myUserExists() {
      return signedIn() && exists(userRef(request.auth.uid));
    }

    function me() {
      return get(userRef(request.auth.uid)).data;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return myUserExists() && me().role == "admin";
    }

    function isManager() {
      return myUserExists() && me().role == "manager" && me().status == "approved";
    }

    function isApprovedTeam() {
      return myUserExists()
        && me().status == "approved"
        && (me().role == "staff" || me().role == "manager");
    }

    function isMyTimesheetId(docId) {
      return signedIn()
        && docId.matches('^' + request.auth.uid + '_[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || isAdmin();

      allow create: if isSelf(uid)
        && request.resource.data.role == "staff"
        && request.resource.data.status == "pending";

      allow update: if isAdmin() || (
        isSelf(uid)
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        && request.resource.data.hourlyRate == resource.data.hourlyRate
        && request.resource.data.email == resource.data.email
      );

      allow delete: if isAdmin();
    }

    match /{anyPath=**}/shifts/{shiftId} {
      allow read: if isAdmin()
        || (isApprovedTeam() && resource.data.uid == request.auth.uid);

      allow create, update, delete: if isAdmin();
    }

    match /rosterWeeks/{weekStart} {
      allow read: if isAdmin() || isApprovedTeam();
      allow create, update, delete: if isAdmin();

      match /shifts/{shiftId} {
        allow read: if isAdmin()
          || (isApprovedTeam() && resource.data.uid == request.auth.uid);

        allow create, update, delete: if isAdmin();
      }
    }

    match /timesheets/{docId} {
      allow read: if isAdmin()
        || (isApprovedTeam() && isMyTimesheetId(docId))
        || (signedIn() && resource.data.uid == request.auth.uid);

      allow create: if isAdmin() || (
        isApprovedTeam()
        && isMyTimesheetId(docId)
        && request.resource.data.uid == request.auth.uid
      );

      allow update: if isAdmin() || (
        isApprovedTeam()
        && isMyTimesheetId(docId)
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.storeId == resource.data.storeId
        && request.resource.data.date == resource.data.date
      );

      allow delete: if isAdmin();
    }

    match /stores/{storeId} {
      allow read: if isAdmin() || isApprovedTeam();
      allow create, update, delete: if isAdmin();
    }

    match /storeSettings/{storeId} {
      allow read: if isAdmin() || isApprovedTeam();
      allow create, update, delete: if isAdmin();
    }

    match /storeQr/{storeId} {
      allow read: if isAdmin() || isApprovedTeam();
      allow create, update, delete: if isAdmin();
    }

    match /dailyStockTake/{stockId} {
      allow read: if isAdmin() || isApprovedTeam();
      allow create, update: if isAdmin() || isApprovedTeam();
      allow delete: if isAdmin();
    }

    match /leaveRequests/{requestId} {
      allow read: if isAdmin() || (
        isApprovedTeam() && resource.data.uid == request.auth.uid
      );

      allow create: if isApprovedTeam()
        && request.resource.data.uid == request.auth.uid;

      allow update: if isAdmin() || (
        isApprovedTeam()
        && resource.data.uid == request.auth.uid
        && resource.data.status == "pending"
        && request.resource.data.uid == resource.data.uid
      );

      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin() || (
        signedIn() && resource.data.uid == request.auth.uid
      );

      allow create, delete: if isAdmin();

      allow update: if isAdmin() || (
        signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
      );
    }

    match /shiftRequests/{requestId} {
      allow read: if isAdmin() || isApprovedTeam();

      allow create: if isApprovedTeam()
        && request.resource.data.requestorUid == request.auth.uid;

      allow update: if isAdmin() || (
        isApprovedTeam()
        && (
          resource.data.requestorUid == request.auth.uid
          || request.resource.data.claimantUid == request.auth.uid
        )
      );

      allow delete: if isAdmin();
    }

    match /inventoryItems/{itemId} {
      allow read: if isAdmin() || isApprovedTeam();
      allow create, update, delete: if isAdmin();
    }

    match /stockTakeSessions/{sessionId} {
      allow read: if isAdmin()
        || isManager()
        || (
          isApprovedTeam()
          && resource.data.department == "kitchen"
          && resource.data.userId == request.auth.uid
        );

      allow create: if isApprovedTeam()
        && request.resource.data.department == "kitchen"
        && request.resource.data.userId == request.auth.uid;

      allow update: if isAdmin()
        || (
          isManager()
          && resource.data.department == "kitchen"
        )
        || (
          isApprovedTeam()
          && resource.data.department == "kitchen"
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.storeId == resource.data.storeId
          && request.resource.data.department == resource.data.department
        );

      allow delete: if isAdmin();

      match /entries/{entryId} {
        allow read: if isAdmin()
          || isManager()
          || (
            isApprovedTeam()
            && get(/databases/$(database)/documents/stockTakeSessions/$(sessionId)).data.userId == request.auth.uid
          );

        allow create, update: if isAdmin()
          || isManager()
          || (
            isApprovedTeam()
            && get(/databases/$(database)/documents/stockTakeSessions/$(sessionId)).data.userId == request.auth.uid
          );

        allow delete: if isAdmin();
      }
    }

    match /payrollDays/{dayId}/entries/{uid} {
      allow read: if isAdmin() || isSelf(uid);
      allow create, update, delete: if isAdmin();
    }

    match /payrollWeeks/{weekId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();

      match /staff/{uid} {
        allow read: if isAdmin() || isSelf(uid);
        allow create, update, delete: if isAdmin();

        match /payments/{paymentId} {
          allow read: if isAdmin() || isSelf(uid);
          allow create, update, delete: if isAdmin();
        }
      }
    }

    match /payrollTotals/{uid} {
      allow read: if isAdmin() || isSelf(uid);
      allow create, update, delete: if isAdmin();

      match /weeks/{weekStart} {
        allow read: if isAdmin() || isSelf(uid);
        allow create, update, delete: if isAdmin();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
